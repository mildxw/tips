<Window x:Class="tips.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tips"
        mc:Ignorable="d"
        Title="Калькулятор чаевых" Height="560" Width="430"
        WindowStartupLocation="CenterScreen"
        Background="#e8e5da">
     
    <Grid Margin="25">
        <Border Background="#e8e5da"
                CornerRadius="24"
                BorderBrush="#304c89"
                BorderThickness="2"
                Padding="24"></Border>
        <StackPanel>

            <TextBlock Text="Калькулятор чаевых"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#304c89"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 8" />

            <TextBlock Text="Расчёт чаевых и суммы на каждого гостя"
                       FontSize="14"
                       Foreground="#304c89"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0 0 0 25" />

            <TextBlock Text="Сумма счёта"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#304c89"/>

            <TextBox x:Name="textBoxbill"
                     Height="38"
                     FontSize="16"
                     Margin="0 6 0 16"
                     Padding="10 6"
                     Background="White"
                     Foreground="#304c89"
                     BorderBrush="#9eb7e5"
                     BorderThickness="2" />

            <TextBlock Text="Количество гостей"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#304c89"/>

            <TextBox x:Name="textBoxGuestsCount"
                     Height="38"
                     FontSize="16"
                     Margin="0 6 0 16"
                     Padding="10 6"
                     Background="White"
                     Foreground="#304c89"
                     BorderBrush="#9eb7e5"
                     BorderThickness="2" />

            <TextBlock Text="Процент чаевых"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#304c89"/>

            <StackPanel Margin=" 0 0 0 20">
                <RadioButton x:Name="radioButtonNoTips"
                             Content="Без чаевых"
                             IsChecked="True"
                             Foreground="#304c89"
                             FontSize="15"
                             Margin="0 3"/>

                <RadioButton x:Name="radioButtonFive"
                             Content="5%"
                             IsChecked="True"
                             Foreground="#304c89"
                             FontSize="15"
                             Margin="0 3"/>

                <RadioButton x:Name="radioButtonTen"
                             Content="10%"
                             IsChecked="True"
                             Foreground="#304c89"
                             FontSize="15"
                             Margin="0 3"/>

                <RadioButton x:Name="radioButtonFifteen"
                             Content="15%"
                             IsChecked="True"
                             Foreground="#304c89"
                             FontSize="15"
                             Margin="0 3"/>
            </StackPanel>

            <Button x:Name="buttonCalculate"
                    Content="Рассчитать"
                    Height="45"
                    FontSize="17"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="#648de5"
                    BorderBrush="#304c89"
                    BorderThickness="1"
                    Click="buttonCalculateClick"
                    Margin="0 0 0 20" />

            <Border Background="#cdc392"
                    CornerRadius="16"
                    Padding="16"
                    BorderBrush="#304c89"
                    BorderThickness="1"/>

            <StackPanel>
                <TextBlock Text="Результат"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#304c89"
                           Margin="0 0 0 8"/>

                <TextBlock x:Name="textBlockResult"
                           Text="Введите данные и нажмите 'Рассчитать'"
                           FontSize="15"
                           Foreground="#304c89"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>


    </Grid>
</Window>
